          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('tripId', jsonData.trip.id);",
                  "    pm.collectionVariables.set('busId', jsonData.trip.bus_id);",
                  "    pm.collectionVariables.set('routeId', jsonData.trip.route_id);",
