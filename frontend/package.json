{
  "name": "bus-tracker-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:driver": "VITE_APP_TYPE=driver vite",
    "dev:student": "VITE_APP_TYPE=student vite",
    "build:driver": "VITE_APP_TYPE=driver vite build",
    "build:student": "VITE_APP_TYPE=student vite build",
    "icons:export:driver": "./scripts/export-app-icons.sh driver",
    "icons:export:student": "./scripts/export-app-icons.sh student",
    "cap:add:driver": "npx cap add android --dir capacitor-driver",
    "cap:add:student": "npx cap add android --dir capacitor-student",
    "cap:sync:driver": "npm run build:driver && npx cap sync android --dir capacitor-driver",
    "cap:sync:student": "npm run build:student && npx cap sync android --dir capacitor-student",
    "cap:open:driver": "npx cap open android --dir capacitor-driver",
    "cap:open:student": "npx cap open android --dir capacitor-student",
    "cap:build:driver": "npm run cap:sync:driver && npm run cap:open:driver",
    "cap:build:student": "npm run cap:sync:student && npm run cap:open:student"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor-firebase/app": "^6.0.0",
    "@capacitor-firebase/messaging": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "laravel-echo": "^2.3.0",
    "leaflet": "^1.9.4",
    "pinia": "^2.2.8",
    "pusher-js": "^8.4.0-rc2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.2",
    "typescript": "^5.9.3",
    "vite": "^6.2.0"
  }
}
