  "item": [
    {
      "name": "Public Routes",
      "description": "Endpoints accessible without authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('driverToken', jsonData.token);",
                  "    pm.collectionVariables.set('driverId', jsonData.user.id);",
                  "    pm.test('Token received', function() {",
                  "        pm.expect(jsonData.token).to.not.be.empty;",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"driver@bubt.edu\",\n    \"password\": \"password123\",\n    \"role\": \"driver\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login for drivers and students. Returns user object and API token."
          },
          "response": []
        },
        {
          "name": "Login as Student",
